{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Data Source=/app/data/blunderforge.db"
  },
  "BlunderForge": {
    "DataDirectory": "/app/data",
    "Stockfish": {
      "Path": "/app/stockfish/stockfish",
      "AnalysisTimeMs": 800,
      "QuickAnalysisTimeMs": 250,
      "Threads": 1,
      "HashSizeMb": 128,
      "MultiPv": 8,
      "OpponentMoveTimeMs": 500,
      "LowEloMultiPv": 8,
      "ProtocolTimeoutMs": 5000
    },
    "AiProvider": {
      "Provider": "DeepSeek",
      "BaseUrl": "https://api.deepseek.com",
      "InteractiveModel": "fake-interactive-model",
      "ReviewModel": "fake-review-model",
      "TimeoutSeconds": 30,
      "MaxRetryCount": 1
    }
  }
}
